msgid "help_desc_import"
msgstr "Puoi importare libri da Gleeph, Goodreads, Babelio o qualsiasi file CSV. Questo ti permette di centralizzare la tua biblioteca in BiblioGenius."

#. Test your memory with your book covers
msgid "help_desc_memory_game"
msgstr "Metti alla prova la tua memoria con le copertine dei libri"

#. View your statistics, badges, goals and leaderboard
msgid "help_desc_profile"
msgstr "Visualizza le tue statistiche, i badge, gli obiettivi e la classifica"

